# PrivateFRP Server — environment variables for Docker (docker-compose.yml)
# Copy this file to .env and fill in the values before running:
#   cp .env.example .env

# Port the server listens on for agent TLS connections
AGENT_PORT=7000

# Port the HTTP dashboard listens on
DASHBOARD_PORT=8080

# Dashboard login credentials in the format user:password
# Change this before exposing the dashboard to the internet
DASHBOARD_SECRET=admin:changeme

# Public IP address of this server, shown in the dashboard tunnel connection strings
# Leave empty to disable; the dashboard will display the raw listen port instead
PUBLIC_IP=
