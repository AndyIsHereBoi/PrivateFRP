{
  "name": "privatefrp",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev:server": "cd packages/server && bun run dev",
    "dev:agent": "cd packages/agent && bun run dev",
    "build:server": "cd packages/server && bun run build",
    "build:agent": "cd packages/agent && bun run build",
    "build:binaries": "bun run build:server && bun run build:agent"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^25.6.0"
  }
}
