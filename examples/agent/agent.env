# Agent connection settings
SERVER_HOST=host.docker.internal
SERVER_PORT=7000
DATA_DIR=/app/data
TRUST_STORE_PATH=/app/data/trusted-server-cert.json

# Agent identity
AGENT_ID=your-agent-id
AGENT_SECRET=your-agent-secret
AGENT_NAME=example-agent

# Optional reconnect tuning
AGENT_RECONNECT_MS=1000

# Optional tunnel seed data can be supplied as JSON if you want a bootstrap config
TUNNELS=[]
