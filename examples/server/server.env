# Server-side agent TLS listener
SERVER_HOST=0.0.0.0
AGENT_PORT=7000
AGENT_TLS_CERT_PATH=certs/agent-server-cert.pem
AGENT_TLS_KEY_PATH=certs/agent-server-key.pem

# Dashboard HTTP listener
DASHBOARD_PORT=8080
PUBLIC_HOST=0.0.0.0
DASHBOARD_PUBLIC_IP=

# Dashboard auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin
DASHBOARD_SESSION_SECRET=change-me-in-production

# Data storage
DATA_DIR=/app/data
DATABASE_PATH=/app/data/privatefrp.sqlite
