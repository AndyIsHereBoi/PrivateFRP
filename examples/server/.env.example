# PrivateFRP Server Configuration

# Server port for agent connections
SERVER_PORT=7000

# Dashboard HTTP API port
DASHBOARD_PORT=8089

# Database path (relative to container working directory)
DATABASE_PATH=./data/privatefrp.db

# TLS Certificate (optional - auto-generated if not provided)
TLS_CERT=

# TLS Private Key (optional - auto-generated if not provided)
TLS_KEY=

# Logging level
LOG_LEVEL=info
