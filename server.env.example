# PrivateFRP Server — environment variables
# Copy this file to server.env and fill in the values before running:
#   cp server.env.example server.env
#
# Docker:  docker compose --env-file server.env up -d
# Bun:     cd packages/server && bun run start  (loads ../../server.env automatically)

# Port the server listens on for agent TLS connections
AGENT_PORT=7000

# Port the HTTP dashboard listens on
DASHBOARD_PORT=8080

# Dashboard login credentials in the format user:password
# Change this before exposing the dashboard to the internet
DASHBOARD_SECRET=admin:changeme

# Public IP address of this server, shown in the dashboard tunnel connection strings
# Leave empty to disable; the dashboard will display the raw listen port instead
PUBLIC_IP=

# Optional: enrich top IP rows in Data Tracking with ASN/org names.
# Uses ipwho.is from the server process. Keep disabled if you want zero outbound lookups.
IP_ASN_LOOKUP=false

# Maximum pending fallback dials per connected agent.
# Increase for bursty web traffic if you see "Too many pending dials" in logs.
SERVER_MAX_PENDING_DIALS=10000

# Fallback dial timeout for TCP/UDP session acquisition (milliseconds).
# Increase if upstream services are healthy but handshakes are timing out under burst.
SERVER_DIAL_TIMEOUT_MS=30000

# Directory where server log files are written.
# Files created: tunnel.log (agent/tunnel logs), webserver.log (dashboard logs)
LOG_PATH=./logs

# --- Bun (non-Docker) only — Docker uses hardcoded /app/* paths ---

# Paths to the TLS certificate and private key (relative to packages/server/ when using bun)
AGENT_TLS_CERT=../../certs/server.crt
AGENT_TLS_KEY=../../certs/server.key

# Directory where the SQLite database file is stored (relative to packages/server/ when using bun)
DATA_DIR=./data
