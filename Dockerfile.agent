# Build stage - uses Bun to compile TypeScript to JS
FROM oven/bun:1.3.10 AS builder

WORKDIR /app

# Copy package files first for better caching
COPY package.json bun.lock ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/agent/package.json ./packages/agent/

# Install dependencies (cached unless package.json changes)
RUN bun install --frozen-lockfile

# Copy source code (this will invalidate cache on code changes)
COPY packages/ ./packages/
COPY tsconfig.json ./

# Build the agent using Bun's bundler
RUN bun build ./packages/agent/src/index.ts \
    --outfile ./dist/agent.js \
    --target bun \
    --minify

# Runtime stage - minimal image with just Bun and compiled JS
FROM oven/bun:1.3.10-slim

WORKDIR /app

# Create non-root user for security
RUN addgroup --system --gid 1001 appgroup && \
    adduser --system --uid 1001 --gid 1001 appuser

# Copy only the compiled output and necessary files
COPY --from=builder /app/dist ./dist
COPY packages/shared/package.json ./packages/shared/

USER appuser

CMD ["bun", "./dist/agent.js"]
