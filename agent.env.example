# PrivateFRP Agent Configuration

# Server hostname or IP address (required)
SERVER_HOST=localhost

# Server port for agent connections
SERVER_PORT=7000

# Agent identifier (required - must be unique per agent)
AGENT_ID=my-agent

# Agent secret for authentication (required)
AGENT_SECRET=my-secret

# Validate server certificate (set to false for self-signed certificates)
TLS_REJECT_UNAUTHORIZED=true
