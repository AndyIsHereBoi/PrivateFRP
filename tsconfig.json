{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["bun", "node"]
  },
  "include": ["packages/**/src/**/*.ts", "packages/**/tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
