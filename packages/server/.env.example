# PrivateFRP Server — environment variables for non-Docker usage (packages/server/)
# Bun automatically loads this file when running from the packages/server/ directory.
# Copy this file to .env and fill in the values:
#   cp packages/server/.env.example packages/server/.env

# Port the server listens on for agent TLS connections
AGENT_PORT=7000

# Port the HTTP dashboard listens on
DASHBOARD_PORT=8080

# Paths to the TLS certificate and private key (relative to packages/server/)
AGENT_TLS_CERT=../../certs/server.crt
AGENT_TLS_KEY=../../certs/server.key

# Dashboard login credentials in the format user:password
# Change this before exposing the dashboard to the internet
DASHBOARD_SECRET=admin:changeme

# Directory where the SQLite database file is stored (relative to packages/server/)
DATA_DIR=./data

# Public IP address of this server, shown in the dashboard tunnel connection strings
# Leave empty to disable
PUBLIC_IP=
